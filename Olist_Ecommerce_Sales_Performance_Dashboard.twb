      <aliases enabled='yes' />
      <column caption='&quot;Order Id&quot;' datatype='string' name='[&quot;order_id&quot;]' role='dimension' type='nominal' />
      <column caption='&quot;Review Answer Timestamp&quot;' datatype='datetime' name='[&quot;review_answer_timestamp&quot;]' role='dimension' type='ordinal' />
      <column caption='&quot;Review Comment Message&quot;' datatype='string' name='[&quot;review_comment_message&quot;]' role='dimension' type='nominal' />
      <column caption='&quot;Review Comment Title&quot;' datatype='string' name='[&quot;review_comment_title&quot;]' role='dimension' type='nominal' />
      <column caption='&quot;Review Creation Date&quot;' datatype='string' name='[&quot;review_creation_date&quot;]' role='dimension' type='nominal' />
      <column caption='&quot;Review Id&quot;' datatype='string' name='[&quot;review_id&quot;]' role='dimension' type='nominal' />
      <column caption='&quot;Review Score&quot;' datatype='integer' name='[&quot;review_score&quot;]' role='measure' type='quantitative' />
      <column caption='Revenue Rank' datatype='integer' name='[Calculation_1111626040791040]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([payment_value]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Seller Segment:' datatype='string' name='[Calculation_1111626043346947]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([payment_value]) &gt;= WINDOW_AVG(SUM([payment_value]))&#13;&#10;AND COUNTD([order_id]) &gt;= WINDOW_AVG(COUNTD([order_id]))&#13;&#10;THEN &quot;Excellent&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([payment_value]) &gt;= WINDOW_AVG(SUM([payment_value]))&#13;&#10;AND COUNTD([order_id]) &lt; WINDOW_AVG(COUNTD([order_id]))&#13;&#10;THEN &quot;Good&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([payment_value]) &lt; WINDOW_AVG(SUM([payment_value]))&#13;&#10;AND COUNTD([order_id]) &gt;= WINDOW_AVG(COUNTD([order_id]))&#13;&#10;THEN &quot;Average&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&quot;Poor&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Revenue Category' datatype='string' name='[Calculation_1913444564963329]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([payment_value]) &gt;= 200000 THEN &quot;Excellent&quot;&#13;&#10;ELSEIF SUM([payment_value]) &gt;= 120000 THEN &quot;Good&quot;&#13;&#10;ELSEIF SUM([payment_value]) &gt;= 70000 THEN &quot;Average&quot;&#13;&#10;ELSE &quot;Poor&quot;&#13;&#10;END' />
      </column>
      <column caption='Delivery Success Rate' datatype='real' name='[Calculation_1913444594245634]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [order_delivered_customer_date] &lt;= [order_estimated_delivery_date] THEN [order_id] END)&#13;&#10;/&#13;&#10;COUNTD(IF NOT ISNULL([order_delivered_customer_date]) THEN [order_id] END)' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_2175401090547712]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value]) / COUNTD([order_id])' />
      </column>
      <column caption='Revenue Display' datatype='string' name='[Calculation_2285628604801024]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([payment_value]) &gt;= 1000000 THEN&#13;&#10;&quot;R$ &quot; + STR(ROUND(SUM([payment_value])/1000000,2)) + &quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([payment_value]) &gt;= 1000 THEN&#13;&#10;STR(ROUND(SUM([payment_value])/1000,2)) + &quot;K&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;STR(INT(SUM([payment_value])))&#13;&#10;END' />
      </column>
      <column caption='Revenue %' datatype='real' default-format='p0.00%' name='[Calculation_2285628633120769]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value]) /&#13;&#10;TOTAL(SUM([payment_value]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Average Review Rating' datatype='real' name='[Calculation_2386508063760385]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([&quot;review_score&quot;])' />
      </column>
      <column caption='Rating Color' datatype='string' name='[Calculation_2386508067602434]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2386508063760385] &gt;= 4.5 THEN &quot;Excellent&quot;&#13;&#10;ELSEIF [Calculation_2386508063760385] &gt;= 4.0 THEN &quot;Good&quot;&#13;&#10;ELSEIF [Calculation_2386508063760385] &gt;= 3.5 THEN &quot;Average&quot;&#13;&#10;ELSEIF [Calculation_2386508063760385] &gt;= 3.0 THEN &quot;Fair&quot;&#13;&#10;ELSE &quot;Poor&quot;&#13;&#10;END' />
      </column>
      <column caption='Customer Type' datatype='string' name='[Calculation_2386508073578499]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { FIXED [customer_unique_id] : COUNTD([order_id]) } = 1 THEN&#13;&#10;    &quot;New Customer&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Returning Customer&quot;&#13;&#10;END' />
      </column>
